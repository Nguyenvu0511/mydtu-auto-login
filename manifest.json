{
  "manifest_version": 3,
  "name": "MyDTU Auto-Login",
  "version": "1.0",
  "description": "Bản quyền thuộc về Atsuki Nguyễn",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://mydtu.duytan.edu.vn/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "options.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mydtu.duytan.edu.vn/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}